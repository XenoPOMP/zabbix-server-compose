# Sets "name" field in compose-file. Is optional
CLUSTER_NAME=zabbix-composed

# Postgresql Database credentials
PGUSER=zabbix
PGPASSWORD=some_password

# Select certain tag for containers. This field is optional.
# See all available versions: https://hub.docker.com/r/zabbix/zabbix-server-pgsql/tags
ZBX_VERSION=7.4.0
# Web-interface will be available by this port
FRONT_END_PORT=8080